{
  "name": "@crawldex/atrs",
  "version": "0.2.0",
  "description": "Agent Trust Record Schema validators and reference schemas.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crawldex/atrs.git"
  },
  "homepage": "https://github.com/crawldex/atrs#readme",
  "bugs": {
    "url": "https://github.com/crawldex/atrs/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "schemas",
    "fixtures",
    "RFCS",
    "README.md",
    "GOVERNANCE.md",
    "IMPLEMENTATIONS.md",
    "LICENSES.md",
    "package.json"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "prepack": "npm run build"
  },
  "keywords": [
    "crawldex",
    "atrs",
    "agent-trust-record",
    "schema"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
